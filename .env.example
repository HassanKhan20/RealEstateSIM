# Groq powers all AI features: in-character chat (Llama 3.3 70B),
# graded scoring + exam generation (JSON mode), and voice-agent
# speech-to-text (Whisper large v3).
#
# Get a key from https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Optional: where waitlist signups are sent. Paste your Google Apps Script
# web-app URL (or Zapier/Make webhook). If unset, signups are logged to the
# server console only.
WAITLIST_WEBHOOK_URL=
